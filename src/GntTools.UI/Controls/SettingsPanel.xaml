<UserControl x:Class="GntTools.UI.Controls.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="0">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- 공통 설정 -->
            <Expander Header="공통" Style="{StaticResource PropertyExpander}" IsExpanded="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.ColumnSpan="2"/>
                    <TextBlock Text="텍스트 스타일" Style="{StaticResource PropertyLabel}" Grid.Row="0" Grid.Column="0"/>
                    <TextBox Text="{Binding TextStyle}" Style="{StaticResource PropertyTextBox}" Grid.Row="0" Grid.Column="1"/>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.ColumnSpan="2"/>
                    <TextBlock Text="텍스트 크기" Style="{StaticResource PropertyLabel}" Grid.Row="1" Grid.Column="0"/>
                    <TextBox Text="{Binding TextSize}" Style="{StaticResource PropertyTextBox}" Grid.Row="1" Grid.Column="1"/>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="2" Grid.ColumnSpan="2"/>
                    <TextBlock Text="연장 자릿수" Style="{StaticResource PropertyLabel}" Grid.Row="2" Grid.Column="0"/>
                    <TextBox Text="{Binding LengthDecimals}" Style="{StaticResource PropertyTextBox}" Grid.Row="2" Grid.Column="1"/>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="3" Grid.ColumnSpan="2"/>
                    <TextBlock Text="심도 자릿수" Style="{StaticResource PropertyLabel}" Grid.Row="3" Grid.Column="0"/>
                    <TextBox Text="{Binding DepthDecimals}" Style="{StaticResource PropertyTextBox}" Grid.Row="3" Grid.Column="1"/>
                </Grid>
            </Expander>

            <!-- 상수 레이어 -->
            <Expander Header="상수 레이어" Style="{StaticResource PropertyExpander}" IsExpanded="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.ColumnSpan="2"/>
                    <TextBlock Text="심도텍스트" Style="{StaticResource PropertyLabel}" Grid.Row="0" Grid.Column="0"/>
                    <TextBox Text="{Binding WtlDepthLayer}" Style="{StaticResource PropertyTextBox}" Grid.Row="0" Grid.Column="1"/>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.ColumnSpan="2"/>
                    <TextBlock Text="지반고텍스트" Style="{StaticResource PropertyLabel}" Grid.Row="1" Grid.Column="0"/>
                    <TextBox Text="{Binding WtlHeightLayer}" Style="{StaticResource PropertyTextBox}" Grid.Row="1" Grid.Column="1"/>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="2" Grid.ColumnSpan="2"/>
                    <TextBlock Text="제원텍스트" Style="{StaticResource PropertyLabel}" Grid.Row="2" Grid.Column="0"/>
                    <TextBox Text="{Binding WtlLabelLayer}" Style="{StaticResource PropertyTextBox}" Grid.Row="2" Grid.Column="1"/>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="3" Grid.ColumnSpan="2"/>
                    <TextBlock Text="지시선" Style="{StaticResource PropertyLabel}" Grid.Row="3" Grid.Column="0"/>
                    <TextBox Text="{Binding WtlLeaderLayer}" Style="{StaticResource PropertyTextBox}" Grid.Row="3" Grid.Column="1"/>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="4" Grid.ColumnSpan="2"/>
                    <TextBlock Text="불탐관로" Style="{StaticResource PropertyLabel}" Grid.Row="4" Grid.Column="0"/>
                    <TextBox Text="{Binding WtlUndetectedLayer}" Style="{StaticResource PropertyTextBox}" Grid.Row="4" Grid.Column="1"/>
                </Grid>
            </Expander>

            <!-- 하수 레이어 -->
            <Expander Header="하수 레이어" Style="{StaticResource PropertyExpander}" IsExpanded="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.ColumnSpan="2"/>
                    <TextBlock Text="심도텍스트" Style="{StaticResource PropertyLabel}" Grid.Row="0" Grid.Column="0"/>
                    <TextBox Text="{Binding SwlDepthLayer}" Style="{StaticResource PropertyTextBox}" Grid.Row="0" Grid.Column="1"/>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.ColumnSpan="2"/>
                    <TextBlock Text="제원텍스트" Style="{StaticResource PropertyLabel}" Grid.Row="1" Grid.Column="0"/>
                    <TextBox Text="{Binding SwlLabelLayer}" Style="{StaticResource PropertyTextBox}" Grid.Row="1" Grid.Column="1"/>
                </Grid>
            </Expander>

            <!-- 전력통신 레이어 -->
            <Expander Header="전력통신 레이어" Style="{StaticResource PropertyExpander}" IsExpanded="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.ColumnSpan="2"/>
                    <TextBlock Text="심도텍스트" Style="{StaticResource PropertyLabel}" Grid.Row="0" Grid.Column="0"/>
                    <TextBox Text="{Binding KepcoDepthLayer}" Style="{StaticResource PropertyTextBox}" Grid.Row="0" Grid.Column="1"/>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.ColumnSpan="2"/>
                    <TextBlock Text="도형레이어" Style="{StaticResource PropertyLabel}" Grid.Row="1" Grid.Column="0"/>
                    <TextBox Text="{Binding KepcoDrawingLayer}" Style="{StaticResource PropertyTextBox}" Grid.Row="1" Grid.Column="1"/>
                </Grid>
            </Expander>

            <!-- 저장 버튼 -->
            <Button Content="저장" Command="{Binding SaveCommand}"
                    Style="{StaticResource PropertyButton}"
                    Width="80" HorizontalAlignment="Center"
                    Margin="0,8"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
