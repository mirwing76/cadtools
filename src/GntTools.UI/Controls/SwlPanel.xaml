<UserControl x:Class="GntTools.UI.Controls.SwlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="0">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/GntTools.UI;component/Styles/PropertyGridStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- 기본정보 -->
            <Expander Style="{StaticResource PropertyExpander}" Header="기본정보" IsExpanded="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.ColumnSpan="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource PropertyLabel}" Text="용도코드" Grid.Column="0"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding UseCode}" Grid.Column="1"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.ColumnSpan="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource PropertyLabel}" Text="설치년도" Grid.Column="0"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding InstallYear}" Grid.Column="1"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="2" Grid.ColumnSpan="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource PropertyLabel}" Text="관재질" Grid.Column="0"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding Material}" Grid.Column="1"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="3" Grid.ColumnSpan="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource PropertyLabel}" Text="구경" Grid.Column="0"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding Diameter}" Grid.Column="1"/>
                        </Grid>
                    </Border>
                </Grid>
            </Expander>

            <!-- 박스관 -->
            <Expander Style="{StaticResource PropertyExpander}" Header="박스관" IsExpanded="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.ColumnSpan="2">
                        <CheckBox Content="박스관" IsChecked="{Binding IsBoxPipe}" Grid.ColumnSpan="2"/>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.ColumnSpan="2"
                            IsEnabled="{Binding IsBoxPipe}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource PropertyLabel}" Text="가로(mm)" Grid.Column="0"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding BoxWidth}" Grid.Column="1"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="2" Grid.ColumnSpan="2"
                            IsEnabled="{Binding IsBoxPipe}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource PropertyLabel}" Text="세로(mm)" Grid.Column="0"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding BoxHeight}" Grid.Column="1"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="3" Grid.ColumnSpan="2"
                            IsEnabled="{Binding IsBoxPipe}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource PropertyLabel}" Text="통로수" Grid.Column="0"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding LineCount}" Grid.Column="1"/>
                        </Grid>
                    </Border>
                </Grid>
            </Expander>

            <!-- 심도 -->
            <Expander Style="{StaticResource PropertyExpander}" Header="심도" IsExpanded="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.ColumnSpan="2">
                        <RadioButton Content="자동측정" IsChecked="{Binding IsAutoDepth}"/>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.ColumnSpan="2">
                        <RadioButton Content="수동입력" IsChecked="{Binding IsManualDepth}"/>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="2" Grid.ColumnSpan="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource PropertyLabel}" Text="시점심도" Grid.Column="0"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding BeginDepth}"
                                     IsEnabled="{Binding IsManualDepth}" Grid.Column="1"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="3" Grid.ColumnSpan="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource PropertyLabel}" Text="종점심도" Grid.Column="0"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding EndDepth}"
                                     IsEnabled="{Binding IsManualDepth}" Grid.Column="1"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="4" Grid.ColumnSpan="2">
                        <CheckBox Content="불탐" IsChecked="{Binding IsUndetected}"/>
                    </Border>
                </Grid>
            </Expander>

            <!-- 지반고 / 표고 -->
            <Expander Style="{StaticResource PropertyExpander}" Header="지반고 / 표고" IsExpanded="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.ColumnSpan="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource PropertyLabel}" Text="시점지반고" Grid.Column="0"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding BeginGroundHeight}" Grid.Column="1"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.ColumnSpan="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource PropertyLabel}" Text="종점지반고" Grid.Column="0"/>
                            <TextBox Style="{StaticResource PropertyTextBox}" Text="{Binding EndGroundHeight}" Grid.Column="1"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="2" Grid.ColumnSpan="2">
                        <Button Style="{StaticResource PropertyButton}" Content="표고 미리보기"
                                Command="{Binding CalcElevationCommand}" HorizontalAlignment="Left"/>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="3" Grid.ColumnSpan="2">
                        <TextBlock Text="{Binding ElevationInfo}"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   FontSize="11" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Expander>

            <!-- 라벨 -->
            <Expander Style="{StaticResource PropertyExpander}" Header="라벨" IsExpanded="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.ColumnSpan="2">
                        <RadioButton Content="지시선" IsChecked="{Binding UseLeader}"/>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.ColumnSpan="2">
                        <RadioButton Content="관로평행"/>
                    </Border>
                </Grid>
            </Expander>

            <!-- 액션 버튼 -->
            <Border Style="{StaticResource PropertyRow}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Style="{StaticResource PropertyButton}" Content="신규입력"
                            Command="{Binding CreateCommand}" Width="80" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource PropertyButton}" Content="수정"
                            Command="{Binding ModifyCommand}" Width="80"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
