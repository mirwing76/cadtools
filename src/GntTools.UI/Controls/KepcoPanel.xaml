<UserControl x:Class="GntTools.UI.Controls.KepcoPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="0">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- 기본정보 -->
            <Expander Style="{StaticResource PropertyExpander}" Header="기본정보">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="설치년도" Style="{StaticResource PropertyLabel}"/>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.Column="1">
                        <TextBox Text="{Binding InstallYear}" Style="{StaticResource PropertyTextBox}"/>
                    </Border>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.Column="0">
                        <TextBlock Text="관재질" Style="{StaticResource PropertyLabel}"/>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.Column="1">
                        <TextBox Text="{Binding Material}" Style="{StaticResource PropertyTextBox}"/>
                    </Border>
                </Grid>
            </Expander>

            <!-- 단면정보 -->
            <Expander Style="{StaticResource PropertyExpander}" Header="단면정보">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.Column="0">
                        <TextBlock Text="단면선택" Style="{StaticResource PropertyLabel}"/>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.Column="1">
                        <Button Content="단면선택" Command="{Binding SelectSectionCommand}"
                                Style="{StaticResource PropertyButton}"/>
                    </Border>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                        <TextBlock Text="{Binding SectionInfo}" Style="{StaticResource PropertyLabel}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="BxH 선택" Style="{StaticResource PropertyLabel}"/>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="2" Grid.Column="1">
                        <Button Content="BxH 선택" Command="{Binding SelectBCommand}"
                                Style="{StaticResource PropertyButton}"/>
                    </Border>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="3" Grid.Column="0">
                        <TextBlock Text="BxH" Style="{StaticResource PropertyLabel}"/>
                    </Border>
                    <Border Style="{StaticResource PropertyRow}" Grid.Row="3" Grid.Column="1">
                        <TextBlock Text="{Binding BxH}" Style="{StaticResource PropertyLabel}"/>
                    </Border>
                </Grid>
            </Expander>

            <!-- 심도 -->
            <Expander Style="{StaticResource PropertyExpander}" Header="심도">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
                        <TextBlock Text="자동측정 (정점별)" Style="{StaticResource PropertyLabel}"/>
                    </Border>

                    <Border Style="{StaticResource PropertyRow}" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                        <CheckBox Content="불탐" IsChecked="{Binding IsUndetected}"/>
                    </Border>
                </Grid>
            </Expander>

            <!-- 버튼 -->
            <Border Style="{StaticResource PropertyRow}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="신규입력" Command="{Binding CreateCommand}"
                            Style="{StaticResource PropertyButton}" Width="70" Margin="0,0,4,0"/>
                    <Button Content="수정" Command="{Binding ModifyCommand}"
                            Style="{StaticResource PropertyButton}" Width="50" Margin="0,0,4,0"/>
                    <Button Content="오류검증" Command="{Binding CheckCommand}"
                            Style="{StaticResource PropertyButton}" Width="70"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
