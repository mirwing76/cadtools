<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- AutoCAD Properties 팔레트 스타일 Expander (삼각형 접기/펼치기) -->
    <Style x:Key="PropertyExpander" TargetType="Expander">
        <Setter Property="IsExpanded" Value="True"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <DockPanel>
                        <!-- 헤더: 삼각형 + 섹션 이름 -->
                        <ToggleButton DockPanel.Dock="Top" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                      Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{DynamicResource SectionHeaderBg}"
                                            BorderBrush="{DynamicResource GridBorder}"
                                            BorderThickness="0,0,0,1" Padding="4,3">
                                        <StackPanel Orientation="Horizontal">
                                            <Path x:Name="Arrow" Data="M 0 0 L 6 4 L 0 8 Z"
                                                  Fill="{DynamicResource TextFg}"
                                                  VerticalAlignment="Center" Margin="0,0,6,0"
                                                  RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="0"/>
                                                </Path.RenderTransform>
                                            </Path>
                                            <TextBlock Text="{TemplateBinding Content}"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextFg}"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Arrow" Property="RenderTransform">
                                                <Setter.Value>
                                                    <RotateTransform Angle="90"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <!-- 내용 -->
                        <ContentPresenter x:Name="Content" Visibility="Visible"/>
                    </DockPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="Content" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 속성 행: 왼쪽 라벨 + 오른쪽 값, 구분선 포함 -->
    <Style x:Key="PropertyRow" TargetType="Border">
        <Setter Property="BorderBrush" Value="{DynamicResource GridBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Background" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource RowHoverBg}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 속성 라벨 (왼쪽) -->
    <Style x:Key="PropertyLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Padding" Value="6,3"/>
    </Style>

    <!-- 속성 값 TextBox (오른쪽) -->
    <Style x:Key="PropertyTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource ValueFg}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4,3"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="CaretBrush" Value="{DynamicResource ValueFg}"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="Background" Value="{DynamicResource SelectionBg}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SelectionBorder}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 버튼 스타일 -->
    <Style x:Key="PropertyButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
        <Setter Property="Background" Value="{DynamicResource SectionHeaderBg}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource GridBorder}"/>
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="Margin" Value="4,2"/>
    </Style>

</ResourceDictionary>
